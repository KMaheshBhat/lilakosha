# LilaKosha-MK1: Environment Volume Mapping
# Map these to your physical D: and E: mounts in production
LILAKOSHA_VOLUME_RAW=/tmp/lk-dry/raw
LILAKOSHA_VOLUME_PROCESSED=/tmp/lk-dry/processed
LILAKOSHA_VOLUME_MODELS=/tmp/lk-dry/models
LILAKOSHA_VOLUME_EXPORTS=/tmp/lk-dry/exports

# LilaKosha-MK1: Infrastructure Services
# Ports for llama-server or litert-lm serve instances
LILAKOSHA_SERVICE_INSPECTOR=http://localhost:8033
LILAKOSHA_SERVICE_TEACHER=http://localhost:8033
